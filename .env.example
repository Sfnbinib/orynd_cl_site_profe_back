# LLM Providers (Phase 3 — BYOK)
# Add your key for the provider you want to use.
# The app works WITHOUT any key (fallback mode).

GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Default LLM provider: groq | openai | anthropic | gemini | ollama
LLM_PROVIDER=groq

# Auth (Phase 5)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Billing (NOWPayments — crypto)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1

# Plans & credits
PLAN_FREE_CREDITS=100
PLAN_PRO_PRICE_USD=29
PLAN_PRO_CREDITS=1500
PLAN_TEAM_PRICE_USD=99
PLAN_TEAM_CREDITS=6000

# Legal versions (bump when you publish a new Terms/Privacy)
TERMS_VERSION=2026-05-31
PRIVACY_VERSION=2026-05-31

# CORS — comma-separated allowed origins (no wildcards in prod)
CORS_ORIGINS=https://oryndai.com,http://localhost:5173,http://localhost:8000

# Server
PORT=8000
